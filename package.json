{
  "name": "pokemon-backend",
  "version": "1.0.0",
  "description": "Backend API for Pokemon filtering application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "esbuild server.js --bundle --platform=node --outfile=dist/server.js",
    "docker:build": "docker build -t pokemon-backend .",
    "docker:run": "docker run -p 3001:3001 pokemon-backend",
    "deploy": "bash ../pokemon-frontend/deploy.sh --backend-only",
    "deploy:skip-build": "bash ../pokemon-frontend/deploy.sh --backend-only --skip-build"
  },
  "keywords": [
    "pokemon",
    "api",
    "nodejs",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "nodemon": "^3.0.1"
  }
}
